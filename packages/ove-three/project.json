{
  "name": "ove-three",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/ove-three/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": [],
      "outputs": ["{workspaceRoot}/dist/ove-three"],
      "options": {
        "command": "cd packages/ove-three && yarn vite build --emptyOutDir"
      },
      "configurations": {
        "demo": {
          "command": "cd packages/ove-three && yarn vite build --mode demo --emptyOutDir"
        },
        "production": {
          "command": "cd packages/ove-three && yarn vite build --emptyOutDir"
        }
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["cd packages/ove-three && yarn vite"]
      },
      "configurations": {
        "ci": {
          "commands": [
            "cd packages/ove-three && yarn vite --host 127.0.0.1 --port 5174 --strictPort"
          ],
          "readyWhen": "ready in"
        }
      }
    },
    "e2e": {
      "executor": "@nx/cypress:cypress",
      "options": {
        "browser": "electron",
        "cypressConfig": "packages/ove-three/cypress.config.js",
        "devServerTarget": "ove-three:start:ci",
        "parallel": false,
        "record": false,
        "testingType": "e2e",
        "video": false
      }
    },
    "lint": {},
    "test": {},
    "version": {}
  }
}
